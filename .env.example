# Connexion Neon Postgres (base A = lecture sms, base B = ecriture sms_analysis)
# Format : postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Intervalle de polling de la table sms (ms)
POLL_INTERVAL_MS=5000

# Nombre de SMS traites par passe
BATCH_SIZE=50

# --- Serveur HTTP (ingestion PDV + dashboard admin) ---
# Port d'ecoute (defaut : 3001 ; surchargé par PORT sur Render/Heroku).
HTTP_PORT=3001
# Bearer token des PDV pour /api/ingest. Si vide ET ADMIN_TOKEN vide, HTTP desactive.
# Generer avec : openssl rand -hex 32
INGEST_TOKEN=
# Bearer token du dashboard pour /sms, /ai. Si vide, ces routes renvoient 503.
ADMIN_TOKEN=
# Duree des sessions dashboard creees apres login reCAPTCHA.
ADMIN_SESSION_TTL_HOURS=24
# Origines autorisees pour CORS (liste virgule-separee). "*" en dev.
# Exemple prod : https://openmoney.vercel.app
ALLOWED_ORIGINS=*

# --- Google reCAPTCHA v2 ---
# Optionnel en dev si le fichier ../recaptchat google KEY/KEY.txt existe.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_KEY_FILE=
RECAPTCHA_TIMEOUT_MS=4000
LOGIN_RATE_LIMIT_MAX=10

# --- Web Push / VAPID ---
# Generer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@openmoney.app

# --- Synchro TECNO « Tecno Ya Niongo » ---
# Cle partenaire (secret) envoyee en header x-api-key. Vide => synchro desactivee.
TECNO_PARTNER_API_KEY=
TECNO_PARTNER_BASE_URL=https://tecno-api-6z50.onrender.com
TECNO_PARTNER_TIMEOUT_MS=15000
# Mettre false pour desactiver la synchro sans retirer la cle.
TECNO_SYNC_ENABLED=true
# Cadence incrementale (15 min) et resync plein (24 h).
TECNO_SYNC_INTERVAL_MS=900000
TECNO_SYNC_FULL_INTERVAL_MS=86400000
