# Connexion Neon Postgres (base A = lecture sms, base B = ecriture sms_analysis)
# Format : postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Intervalle de polling de la table sms (ms)
POLL_INTERVAL_MS=5000

# Nombre de SMS traites par passe
BATCH_SIZE=50

# --- Serveur HTTP (ingestion PDV + dashboard admin) ---
# Port d'ecoute (defaut : 3001 ; surchargé par PORT sur Render/Heroku).
HTTP_PORT=3001
# Bearer token des PDV pour /api/ingest. Si vide ET ADMIN_TOKEN vide, HTTP desactive.
# Generer avec : openssl rand -hex 32
INGEST_TOKEN=
# Bearer token du dashboard pour /sms, /ai. Si vide, ces routes renvoient 503.
ADMIN_TOKEN=
# Origines autorisees pour CORS (liste virgule-separee). "*" en dev.
# Exemple prod : https://openmoney.vercel.app
ALLOWED_ORIGINS=*

# --- Web Push / VAPID ---
# Generer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@openmoney.app
