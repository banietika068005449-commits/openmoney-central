# Connexion Neon Postgres (base A = lecture sms, base B = ecriture sms_analysis)
# Format : postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Intervalle de polling de la table sms (ms)
POLL_INTERVAL_MS=5000

# Nombre de SMS traites par passe
BATCH_SIZE=50

# --- Ingestion HTTP depuis les points de vente (optionnel) ---
# Port d'ecoute du serveur HTTP (defaut : 3001)
HTTP_PORT=3001
# Bearer token partage avec les PDV. Si vide, l'endpoint HTTP est desactive.
# Generer avec : openssl rand -hex 32
INGEST_TOKEN=
